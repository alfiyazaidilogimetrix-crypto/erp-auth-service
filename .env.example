# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/erp_db
PORT=4043

# User JWT Configuration
USER_JWT_SECRET=your_user_jwt_secret_here
USER_JWT_REFRESH_SECRET=your_user_refresh_secret_here
USER_JWT_EXPIRE=15m
USER_JWT_REFRESH_EXPIRE=7d

# Admin JWT Configuration
ADMIN_JWT_SECRET=your_admin_jwt_secret_here
ADMIN_JWT_REFRESH_SECRET=your_admin_refresh_secret_here
ADMIN_JWT_EXPIRE=15m
ADMIN_JWT_REFRESH_EXPIRE=7d

# OTP JWT Configuration
OTP_JWT_SECRET=your_otp_jwt_secret_here
OTP_JWT_EXPIRE=5m

# Email Configuration
EMAIL_API_KEY=your_email_api_key_here
EMAIL=noreply@yourcompany.com
BCC=admin@yourcompany.com
